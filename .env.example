# ============================================================================
# MCP Research Agent - Environment Variables Template
# ============================================================================
# 
# This file serves as a template. Copy the relevant sections to:
#   - backend/.env (for backend API)
#   - frontend/.env.local (for frontend UI)
#   - mcp_servers/*/. env (for MCP servers, if running separately)
#
# NEVER commit actual .env files with real API keys!
# ============================================================================

# ============================================================================
# BACKEND CONFIGURATION (Copy to: backend/.env)
# ============================================================================

# --- API Keys ---
# Anthropic Claude API (Required)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Tavily AI Search API (Required - FREE: 1000 searches/month)
# Get key at: https://tavily.com (no credit card required!)
TAVILY_API_KEY=tvly-your-key-here

# LangSmith (Optional - for observability/tracing)
# Get key at: https://smith.langchain.com/
LANGSMITH_API_KEY=lsv2_your-key-here
LANGSMITH_PROJECT=mcp-research-agent
LANGSMITH_TRACING_V2=true

# --- Gmail MCP Configuration ---
GMAIL_CREDENTIALS_PATH=./mcp_servers/gmail/credentials.json
GMAIL_TOKEN_PATH=./mcp_servers/gmail/token.json

# --- MCP Server URLs (for Railway/production deployment) ---
GMAIL_MCP_URL=http://localhost:3001
SEARCH_MCP_URL=http://localhost:3002

# --- Database ---
# Development: SQLite
DATABASE_URL=sqlite:///./research_agent.db
# Production: PostgreSQL (Railway auto-injects this)
# DATABASE_URL=postgresql://user:pass@host:5432/db

# --- Redis (Optional - for caching) ---
REDIS_URL=redis://localhost:6379

# --- Application Settings ---
ENVIRONMENT=development
DEBUG=true
MAX_SUB_QUERIES=5
MAX_RETRY_ATTEMPTS=2
REQUEST_TIMEOUT=120

# --- CORS (allow frontend origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Railway Production (auto-injected, don't set manually) ---
# RAILWAY_POSTGRES_URL=
# RAILWAY_REDIS_URL=
# PORT=

# ============================================================================
# FRONTEND CONFIGURATION (Copy to: frontend/.env.local)
# ============================================================================

# Backend API URL
# Development:
VITE_API_URL=http://localhost:8000
# Production:
# VITE_API_URL=https://your-backend-api.railway.app

# ============================================================================
# MCP SERVERS CONFIGURATION (Optional - if running MCP servers separately)
# ============================================================================

# --- Gmail MCP (Copy to: mcp_servers/gmail/.env) ---
# GMAIL_CREDENTIALS_PATH=./credentials.json
# GMAIL_TOKEN_PATH=./token.json

# --- Search MCP (Copy to: mcp_servers/search/.env) ---
# TAVILY_API_KEY=tvly-your-key-here

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. Backend Setup:
#    cp .env.example backend/.env
#    # Edit backend/.env and add your API keys
#
# 2. Frontend Setup:
#    echo "VITE_API_URL=http://localhost:8000" > frontend/.env.local
#
# 3. Get API Keys:
#    - Anthropic: https://console.anthropic.com/
#    - Tavily: https://tavily.com (free, no credit card)
#    - LangSmith: https://smith.langchain.com/ (optional)
#
# 4. Gmail MCP Setup (optional, for email functionality):
#    See: docs/MCP_INTEGRATION_GUIDE.md
#
# ============================================================================
